    <contexts>
      <context name="Normal" attribute="Normal Text" lineEndContext="#stay">
        <DetectSpaces/>
        <StringDetect attribute="Comment" context="BlockComment" String="{*"/>
        <Detect2Chars attribute="Comment" context="LineComment" char="-" char1="-"/>
        <DetectChar attribute="String" context="String" char="&quot;"/>
        <keyword attribute="Keyword" context="#stay" String="keywords"/>
        <keyword attribute="Constant" context="#stay" String="constants"/>
        <keyword attribute="Built-in" context="#stay" String="builtins"/>
        <keyword attribute="Data Type" context="#stay" String="types"/>
        <HlCOct attribute="Number" context="#stay"/>
        <Int attribute="Number" context="#stay"/>
        <Float attribute="Number" context="#stay"/>
        <DetectChar attribute="Operator" context="#stay" char="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="=" char1="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="!" char1="="/>
        <Detect2Chars attribute="Operator" context="#stay" char="=" char1="&gt;"/>
        <Detect2Chars attribute="Operator" context="#stay" char="." char1="."/>
        <Detect2Chars attribute="Operator" context="#stay" char="-" char1="&gt;"/>
        <Detect2Chars attribute="Operator" context="#stay" char="&lt;" char1="&lt;"/>
        <AnyChar attribute="Operator" context="#stay" String="+-*/^%#|&amp;&lt;&gt;@!~"/>
        <DetectChar attribute="Symbol" context="#stay" char="{"/>
        <DetectChar attribute="Symbol" context="#stay" char="}"/>
        <DetectChar attribute="Symbol" context="#stay" char="("/>
        <DetectChar attribute="Symbol" context="#stay" char=")"/>
        <DetectChar attribute="Symbol" context="#stay" char="["/>
        <DetectChar attribute="Symbol" context="#stay" char="]"/>
        <DetectChar attribute="Symbol" context="#stay" char=";"/>
        <DetectChar attribute="Symbol" context="#stay" char=","/>
      </context>
      <context name="LineComment" attribute="Comment" lineEndContext="#pop">
        <DetectSpaces/>
        <IncludeRules context="##Comments"/>
      </context>
      <context name="BlockComment" attribute="Comment" lineEndContext="#stay">
        <StringDetect attribute="Comment" context="#pop" String="*}"/>
      </context>
      <context name="String" attribute="String" lineEndContext="#stay">
        <Detect2Chars attribute="Escaped" context="#stay" char="\" char1="&quot;"/>
        <Detect2Chars attribute="Escaped" context="#stay" char="\" char1="\"/>
        <Detect2Chars attribute="Escaped" context="#stay" char="\" char1="n"/>
        <Detect2Chars attribute="Escaped" context="#stay" char="\" char1="t"/>
        <DetectChar attribute="String" context="#pop" char="&quot;"/>
      </context>
    </contexts>
    <itemDatas>
